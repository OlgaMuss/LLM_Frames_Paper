library(readr)
library(dplyr)
library(readxl)
library(tidyr)

df <- read.csv('/Users/lleisten/Library/CloudStorage/OneDrive-ETHZurich/PhD/2023/Projects/BuildBots/Deployment/Analysis/BuildBots_children_T1_November+7,+2025_03.13.csv', header=TRUE)

# remove added x column
df <- df[-c(1,2), ]

summary(df)

# Define the columns that represent the knowledge questions (BI to EA11)
knowledge_columns <- c(
  "robotparts_1", "robotparts_2", "sensors_1", "sensors_2", 
  "microcontrollers_1", "microcontrollers_2", "AI_DA09", "CA12", 
  "CI29", "CI31", "UA19", "GA10", "LLMdesign_1", "GA13", 
  "EA05", "GA04", "PR1", "PR2", "PR3", "PR4", "GA17", "GA16", "EA11"
)

df$robotparts_1 <- as.numeric(df$robotparts_1)
df$robotparts_2 <- as.numeric(df$robotparts_2)
df$sensors_1 <- as.numeric(df$sensors_1)
df$sensors_2 <- as.numeric(df$sensors_2)
df$microcontrollers_1 <- as.numeric(df$microcontrollers_1)
df$microcontrollers_2 <- as.numeric(df$microcontrollers_2)
df$AI_DA09 <- as.numeric(df$AI_DA09)
df$CA12 <- as.numeric(df$CA12)
df$CI29 <- as.numeric(df$CI29)
df$CI31 <- as.numeric(df$CI31)
df$UA19 <- as.numeric(df$UA19)
df$GA10 <- as.numeric(df$GA10)
df$LLMdesign_1 <- as.numeric(df$LLMdesign_1)
df$GA13 <- as.numeric(df$GA13)
df$EA05 <- as.numeric(df$EA05)
df$GA04 <- as.numeric(df$GA04)
df$PR1 <- as.numeric(df$PR1)
df$PR2 <- as.numeric(df$PR2)
df$PR3 <- as.numeric(df$PR3)
df$PR4 <- as.numeric(df$PR4)
df$GA17 <- as.numeric(df$GA17)
df$GA16 <- as.numeric(df$GA16)
df$EA11 <- as.numeric(df$EA11)


summary(df)

sum(c(
  "robotparts_1", "robotparts_2", "sensors_1", "sensors_2", 
  "microcontrollers_1", "microcontrollers_2", "AI_DA09", "CA12", 
  "CI29", "CI31", "UA19", "GA10", "LLMdesign_1", "GA13", 
  "EA05", "GA04", "PR1", "PR2", "PR3", "PR4", "GA17", "GA16", "EA11"
))


## calculate sums of correct / don't know 
average_counts <- df %>%
  rowwise() %>% # Tell dplyr to perform the next step for each subject
  # Create new columns for the sum of each answer type
  mutate(
    correct_total = sum(c_across(all_of(knowledge_columns)) == 1, na.rm = TRUE),
    wrong_total = sum(c_across(all_of(knowledge_columns)) == 0, na.rm = TRUE),
    dont_know_total = sum(c_across(all_of(knowledge_columns)) == 99, na.rm = TRUE)
  ) %>%
  ungroup() %>% # Stop the row-wise operation
  # Calculate the average of these new columns across all 29 subjects
  summarise(
    mean_correct_answers = mean(correct_total),
    mean_wrong_answers = mean(wrong_total),
    mean_dont_know_answers = mean(dont_know_total)
  )

# 3. Print the result
print(average_counts)
