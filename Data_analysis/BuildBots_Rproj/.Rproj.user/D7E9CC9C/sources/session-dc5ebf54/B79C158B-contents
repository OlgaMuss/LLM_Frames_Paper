# Calculate the total number of responses per timepoint
# Assuming a 'response' is a non-NA row in the original dataframe
n_responses_per_timepoint <- df %>%
  group_by(Timepoint) %>%
  summarise(N = n(), .groups = 'drop')

# --- 5. MAILS "I Don't Know" (99) Proportion Plot ---
mails_idk_data <- df %>%
  select(Timepoint, all_of(mails_cols)) %>%
  # Convert to long format
  pivot_longer(cols = all_of(mails_cols), names_to = "Item", values_to = "Response") %>%
  # Count total responses and 99s per Timepoint
  group_by(Timepoint) %>%
  summarise(
    Count_99 = sum(Response == 99, na.rm = TRUE),
    Total_Possible_Responses = n(),
    .groups = 'drop'
  ) %>%
  # Calculate proportion of 99s
  mutate(Proportion_99 = Count_99 / Total_Possible_Responses)

plot_mails_idk <- ggplot(mails_idk_data, aes(x = Timepoint, y = Proportion_99, group = 1)) +
  geom_line(color = "firebrick", size = 1) +
  geom_point(color = "firebrick", size = 3) +
  geom_text(aes(label = scales::percent(Proportion_99, accuracy = 0.1)), vjust = -1) +
  scale_y_continuous(labels = scales::percent) +
  labs(
    title = "Proportion of 'I Don't Know' (99) Responses for MAILS",
    x = "Timepoint",
    y = "Proportion of Total MAILS Responses (across all items)",
    caption = "Plots the percentage of all MAILS scale item responses that were 99."
  ) +
  theme_minimal()
