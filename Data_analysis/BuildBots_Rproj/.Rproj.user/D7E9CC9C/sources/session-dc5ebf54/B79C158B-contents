# --- 7. Robot Perception "I Don't Know" (99) Proportion Plot (Separate Lines) ---
perception_idk_data <- df %>%
  select(Timepoint, all_of(perception_cols)) %>%
  # Convert to long format
  pivot_longer(cols = all_of(perception_cols), names_to = "Item", values_to = "Response") %>%
  # Extract Robot name from the item column
  mutate(
    Robot = case_when(
      str_detect(Item, "NAO") ~ "NAO",
      str_detect(Item, "Blossom") ~ "Blossom",
      str_detect(Item, "Marty") ~ "Marty",
      TRUE ~ "Other"
    )
  ) %>%
  # Group by Timepoint and Robot, then summarize
  group_by(Timepoint, Robot) %>%
  summarise(
    Count_99 = sum(Response == 99, na.rm = TRUE),
    Total_Possible_Responses = n(),
    .groups = 'drop'
  ) %>%
  # Calculate proportion of 99s
  mutate(Proportion_99 = Count_99 / Total_Possible_Responses)

plot_perception_idk <- ggplot(perception_idk_data, aes(x = Timepoint, y = Proportion_99, group = Robot, color = Robot)) +
  geom_line(size = 1) +
  geom_point(size = 3) +
  scale_y_continuous(labels = scales::percent) +
  labs(
    title = "Proportion of 'I Don't Know' (99) Responses for Robot Perception",
